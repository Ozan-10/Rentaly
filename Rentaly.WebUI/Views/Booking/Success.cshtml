@{
    Layout = "~/Views/Shared/_RentalyLayout.cshtml";
}

<section class="pt80 pb80">
    <div class="container">
        <div class="col-lg-8 offset-lg-2">

            <div class="text-center p-5 bg-white shadow rounded">

                <div style="font-size:70px;color:#22c55e;">✔</div>

                <h1 class="text-success mt-3">
                    Rezervasyonunuz Alındı! 🎉
                </h1>

                <p class="mt-3 text-muted">
                    Rezervasyon talebiniz başarıyla oluşturuldu.<br />
                    Ekibimiz kısa süre içinde talebinizi inceleyerek
                    sizinle iletişime geçecektir.
                </p>

                <div class="row mt-5">

                    <div class="col-md-4 mb-3">
                        <div class="border rounded p-3">
                            <h6>Onay Süresi</h6>
                            <strong>1-2 İş Günü</strong>
                        </div>
                    </div>

                    <div class="col-md-4 mb-3">
                        <div class="border rounded p-3">
                            <h6>Bildirim</h6>
                            <strong>E-Posta ile</strong>
                        </div>
                    </div>

                    <div class="col-md-4 mb-3">
                        <div class="border rounded p-3">
                            <h6>Destek</h6>
                            <strong>7/24 Hizmet</strong>
                        </div>
                    </div>

                </div>

                <div class="alert alert-success mt-4 text-start">
                    <strong>Rezervasyon Durumu:</strong> Beklemede <br />
                    Admin onayından sonra rezervasyonunuz aktif hale gelecektir.
                </div>

                <div class="mt-4">

                    <a href="/Car/CarList" class="btn btn-success me-2 px-4">
                        Araçlara Dön
                    </a>

                    <a href="/Home/Index" class="btn btn-light border px-4">
                        Ana Sayfa
                    </a>

                </div>

            </div>

        </div>
    </div>
</section>
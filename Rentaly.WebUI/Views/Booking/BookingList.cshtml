@model List<Rentaly.EntityLayer.Entities.Booking>

@{
    ViewData["Title"] = "Rezervasyonlar";
    Layout = "~/Views/AdminLayout/Index.cshtml";

    int count = 0;
}

<div class="container-fluid mt-4">

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body">

            <h2 class="fw-bold mb-4">Son Rezervasyonlar</h2>

            <div class="table-responsive">
                <table class="table table-hover align-middle">

                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Müşteri</th>
                            <th>Araç</th>
                            <th>Tarih</th>
                            <th>Tutar</th>
                            <th>Durum</th>
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var item in Model.Take(15))
                        {
                            count++;

                            var id = count;

                            string[] carNames =
                            {
                                                "Mercedes EQE",
                                                "BMW M5",
                                                "Audi A6",
                                                "Honda Civic",
                                                "Tesla Model Y",
                                                "Volkswagen Golf",
                                                "Toyota Corolla",
                                                "Range Rover",
                                                "Fiat Egea",
                                                "Porsche Taycan"
                                                };

                            string[] prices =
                            {
                                                "15.000 ₺",
                                                "30.000 ₺",
                                                "18.000 ₺",
                                                "12.500 ₺",
                                                "16.000 ₺",
                                                "21.000 ₺",
                                                "9.000 ₺",
                                                "24.000 ₺",
                                                "17.500 ₺",
                                                "36.000 ₺"
                                                };

                            var carName = carNames[(count - 1) % 10];
                            var totalPrice = prices[(count - 1) % 10];

                            <tr>

                                <td class="fw-bold">#@count</td>

                                <td>
                                    <strong>@item.Name @item.Surname</strong><br />
                                    <small class="text-muted">@item.Phone</small>
                                </td>

                                <td>@carName</td>

                                <td>
                                    @item.PickUpDate.ToShortDateString()<br />
                                    @item.ReturnDate.ToShortDateString()
                                </td>

                                <td class="text-success fw-bold">
                                    @totalPrice
                                </td>

                                <td>
                                    @if (count % 5 == 0)
                                    {
                                        <span class="badge bg-danger">İptal</span>
                                    }
                                    else if (item.IsApproved)
                                    {
                                        <span class="badge bg-success">Onaylandı</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">Beklemede</span>
                                    }
                                </td>

                            </tr>
                        }

                    </tbody>

                </table>
            </div>

        </div>
    </div>

</div>
@model List<Rentaly.EntityLayer.Entities.Process>

@{
    ViewData["Title"] = "Process List";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<h1>Process Listesi</h1>

<a href="/Process/CreateProcess/" class="btn btn-success">Yeni Process Ekle</a>
<br />
<br />

<table class="table table-bordered">
    <tr>
        <th>ID</th>
        <th>Başlık</th>
        <th>Açıklama</th>
        <th>Icon</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.ProcessId</td>
            <td>@item.Title</td>
            <td>@item.Description</td>
            <td>@item.Icon</td>
        </tr>
    }
</table>